(define (problem driverlog-l4-d2-t2-p3-pg75-dg75-tg75)
  (:domain driverlog)
  (:objects
      s0 s1 s2 s3 - location
      driver1 driver2 - driver
      truck1 truck2 - truck
      package1 package2 package3 - obj
  )
  (:init
    (link s0 s1)
    (link s1 s0)
    (link s0 s2)
    (link s2 s0)
    (link s0 s3)
    (link s3 s0)
    (link s1 s2)
    (link s2 s1)
    (link s1 s3)
    (link s3 s1)
    (link s2 s3)
    (link s3 s2)
    (path s0 s1)
    (path s1 s0)
    (path s0 s3)
    (path s3 s0)
    (path s1 s2)
    (path s2 s1)
    (path s1 s3)
    (path s3 s1)
    (path s2 s3)
    (path s3 s2)
    (at driver1 s0)
    (at driver2 s1)
    (at truck1 s2)
    (at truck2 s3)
    (empty truck1)
    (empty truck2)
    (at package1 s1)
    (at package2 s3)
    (at package3 s0)
  )
  (:goal
    (and
      (at package1 s3)
      (at package2 s2)
      (at package3 s2)
      (at driver1 s3)
      (at driver2 s0)
      (at truck1 s1)
      (at truck2 s1)
    )
  )
)
