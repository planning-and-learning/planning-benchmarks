(define (problem driverlog-l4-d3-t2-p2-pg75-dg50-tg50)
  (:domain driverlog)
  (:objects
      s0 s1 s2 s3 - location
      driver1 driver2 driver3 - driver
      truck1 truck2 - truck
      package1 package2 - obj
  )
  (:init
    (link s0 s1)
    (link s1 s0)
    (link s0 s2)
    (link s2 s0)
    (link s0 s3)
    (link s3 s0)
    (link s1 s2)
    (link s2 s1)
    (link s1 s3)
    (link s3 s1)
    (link s2 s3)
    (link s3 s2)
    (path s0 s1)
    (path s1 s0)
    (path s0 s2)
    (path s2 s0)
    (path s0 s3)
    (path s3 s0)
    (path s1 s2)
    (path s2 s1)
    (path s2 s3)
    (path s3 s2)
    (at driver1 s3)
    (at driver2 s1)
    (at driver3 s2)
    (at truck1 s2)
    (at truck2 s2)
    (empty truck1)
    (empty truck2)
    (at package1 s2)
    (at package2 s3)
  )
  (:goal
    (and
      (at package1 s3)
      (at driver1 s2)
      (at driver3 s1)
      (at truck1 s0)
      (at truck2 s0)
    )
  )
)
