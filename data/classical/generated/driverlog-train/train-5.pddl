    (link s1 s0)
    (link s0 s2)
    (link s2 s0)
    (link s0 s3)
    (link s3 s0)
    (link s1 s2)
    (link s2 s1)
    (link s1 s3)
    (link s3 s1)
    (link s2 s3)
    (link s3 s2)
    (path s0 s1)
    (path s1 s0)
    (path s0 s2)
    (path s2 s0)
    (path s1 s2)
    (path s2 s1)
    (path s1 s3)
    (path s3 s1)
    (path s2 s3)
    (path s3 s2)
    (at driver1 s2)
    (at truck1 s0)
    (at truck2 s2)
