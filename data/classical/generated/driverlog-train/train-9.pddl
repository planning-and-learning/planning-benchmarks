(define (problem driverlog-l4-d2-t1-p1-pg50-dg100-tg100)
  (:domain driverlog)
  (:objects
      s0 s1 s2 s3 - location
      driver1 driver2 - driver
      truck1 - truck
      package1 - obj
  )
  (:init
    (link s0 s1)
    (link s1 s0)
    (link s0 s2)
    (link s2 s0)
    (link s0 s3)
    (link s3 s0)
    (link s1 s2)
    (link s2 s1)
    (link s1 s3)
    (link s3 s1)
    (link s2 s3)
    (link s3 s2)
    (path s0 s1)
    (path s1 s0)
    (path s0 s3)
    (path s3 s0)
    (path s1 s2)
    (path s2 s1)
    (path s1 s3)
    (path s3 s1)
    (path s2 s3)
    (path s3 s2)
    (at driver1 s3)
    (at driver2 s2)
    (at truck1 s3)
    (empty truck1)
    (at package1 s1)
  )
  (:goal
    (and
      (at package1 s0)
      (at driver1 s2)
      (at driver2 s3)
      (at truck1 s0)
    )
  )
)
