(define (problem driverlog-l4-d2-t4-p4-pg50-dg100-tg100)
  (:domain driverlog)
  (:objects
      s0 s1 s2 s3 - location
      driver1 driver2 - driver
      truck1 truck2 truck3 truck4 - truck
      package1 package2 package3 package4 - obj
  )
  (:init
    (link s0 s1)
    (link s1 s0)
    (link s0 s2)
    (link s2 s0)
    (link s0 s3)
    (link s3 s0)
    (link s1 s2)
    (link s2 s1)
    (link s1 s3)
    (link s3 s1)
    (link s2 s3)
    (link s3 s2)
    (path s0 s1)
    (path s1 s0)
    (path s0 s3)
    (path s3 s0)
    (path s1 s2)
    (path s2 s1)
    (path s1 s3)
    (path s3 s1)
    (path s2 s3)
    (path s3 s2)
    (at driver1 s3)
    (at driver2 s2)
    (at truck1 s3)
    (at truck2 s1)
    (at truck3 s2)
    (at truck4 s2)
    (empty truck1)
    (empty truck2)
    (empty truck3)
    (empty truck4)
    (at package1 s0)
    (at package2 s0)
    (at package3 s1)
    (at package4 s1)
  )
  (:goal
    (and
      (at package1 s2)
      (at package2 s2)
      (at driver1 s1)
      (at driver2 s1)
      (at truck1 s0)
      (at truck2 s0)
      (at truck3 s1)
      (at truck4 s0)
    )
  )
)
